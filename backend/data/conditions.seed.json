        { "type": "symptom", "id": "yellow_leaves" }
      ],
      "contradictionsAny": []
    },
    "treatment": [
      "Catch early; scrape off a few with a fingernail.",
      "Spot-treat with rubbing alcohol on a cotton swab; prune heavy areas.",
      "Repeat weekly treatments for several weeks if using indoor-labeled products."
