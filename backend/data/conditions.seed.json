    "citations": [{ "title": "Insect Pests – Scale", "url": "https://yardandgarden.extension.iastate.edu/how-to/diagnosing-houseplant-problems-caused-insect-pests", "accessedAt": "2026-02-24" }]
  },

  {
    "id": "fungus_gnats",
    "name": "Fungus gnats (often indicates overwatering)",
    "category": "pest",
    "rules": {
      "requiredAny": [{ "type": "symptom", "id": "flying_black_gnats" }],
      "supportingAny": [{ "type": "observation", "id": "soil_moisture", "op": "eq", "value": "wet" }],
      "contradictionsAny": []
    },
    "treatment": [
