  {
    "id": "crown_root_rot",
    "name": "Crown/root rot (water molds/fungi favored by wet soils)",
    "category": "disease",
    "rules": {
      "requiredAny": [{ "type": "symptom", "id": "mushy_roots" }],
      "supportingAny": [
        { "type": "observation", "id": "soil_moisture", "op": "eq", "value": "wet" },
