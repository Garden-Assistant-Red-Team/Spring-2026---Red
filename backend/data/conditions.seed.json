  {
    "id": "scale_insects",
    "name": "Scale insects",
    "category": "pest",
    "rules": {
      "requiredAny": [{ "type": "symptom", "id": "bumps_on_stems" }],
      "supportingAny": [
        { "type": "symptom", "id": "sticky_residue" },
