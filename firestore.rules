rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // plantCatalog — global read, no client writes
    match /plantCatalog/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Deprecated global plants collection — no writes allowed
    match /plants/{docId} {
      allow read: if false;
      allow write: if false;
    }

    // User documents — only accessible by the owner
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // All subcollections under users/{uid} (plants, reminders, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }

  }
}